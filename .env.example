# ==============================================================================
# .env.example — 环境变量模板
# ==============================================================================
# 使用方法：
#   cp .env.example .env
#   然后编辑 .env，填写真实值
#
# 注意：.env 文件包含密钥，已加入 .gitignore，切勿提交到代码仓库！
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL 数据库配置
# ------------------------------------------------------------------------------
POSTGRES_DB=rag_db          # 数据库名称
POSTGRES_USER=rag_user      # 数据库用户名
POSTGRES_PASSWORD=zmy@123456  # ⚠️ 必须修改为强密码！

# ------------------------------------------------------------------------------
# Redis 配置
# 若不需要密码认证，将 REDIS_PASSWORD 置空即可
# ------------------------------------------------------------------------------
REDIS_PASSWORD=your_redis_password_here       # Redis 访问密码（留空则不启用认证）

# ------------------------------------------------------------------------------
# LLM 配置（DeepSeek 或其他 OpenAI 兼容接口）
# 支持：DeepSeek / 智谱 GLM / OpenAI / 通义千问 / Moonshot 等
# ------------------------------------------------------------------------------
LLM_API_KEY=sk-your-deepseek-api-key          # ⚠️ 必须填写！
LLM_BASE_URL=https://api.deepseek.com/v1      # API 基础地址
LLM_MODEL=deepseek-chat                       # 模型名称

# ------------------------------------------------------------------------------
# Embedding 配置（向量化接口）
# 可与 LLM 使用同一个 API Key，也可使用不同服务
# 示例（智谱 AI）：
#   EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   EMBEDDING_MODEL=embedding-3
# 示例（DeepSeek，暂不支持 Embedding，需用智谱/OpenAI）：
#   EMBEDDING_BASE_URL=https://api.deepseek.com/v1
# ------------------------------------------------------------------------------
EMBEDDING_API_KEY=sk-your-embedding-api-key   # ⚠️ 必须填写！
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3

# ------------------------------------------------------------------------------
# Nginx 配置
# ------------------------------------------------------------------------------
NGINX_PORT=80          # 对外暴露端口（若 80 被占用，改为 8080 等）

# ------------------------------------------------------------------------------
# 应用配置（可选，有默认值）
# ------------------------------------------------------------------------------
CHUNK_SIZE=500         # 文档切块大小（字符数）
CHUNK_OVERLAP=50       # 切块重叠字符数（保留上下文连贯性）
