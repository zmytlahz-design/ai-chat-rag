# ==============================================================================
# .env.example — 环境变量模板
# ==============================================================================
# 使用方法：
#   cp .env.example .env
#   然后编辑 .env，填写真实值
#
# 注意：.env 文件包含密钥，已加入 .gitignore，切勿提交到代码仓库！
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL 数据库配置
# ------------------------------------------------------------------------------
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# LLM 配置（智谱 BigModel，OpenAI 兼容接口）
# 文档：https://open.bigmodel.cn （控制台获取 API Key）
# ------------------------------------------------------------------------------
LLM_API_KEY=your-zhipu-api-key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL_NAME=glm-4-flash

# ------------------------------------------------------------------------------
# Embedding 配置（向量化，智谱 OpenAI 兼容）
# 可与 LLM 使用同一个 API Key
# ------------------------------------------------------------------------------
EMBEDDING_API_KEY=your-zhipu-api-key
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL_NAME=embedding-3

# ------------------------------------------------------------------------------
# 前端容器对外端口（映射到 frontend 容器 80）
# ------------------------------------------------------------------------------
FRONTEND_PORT=80

# ------------------------------------------------------------------------------
# 应用配置（可选，有默认值）
# ------------------------------------------------------------------------------
DEBUG=true
CHUNK_SIZE=500
CHUNK_OVERLAP=50
