# ==================================================
# 环境变量配置示例文件
# 使用方法：复制此文件为 .env，然后填写真实的值
#   cp .env.example .env
# 注意：.env 文件包含密钥，不要提交到 Git！
# ==================================================

# ---------- 应用配置 ----------
APP_NAME=AI 知识库对话系统
APP_VERSION=0.1.0
DEBUG=true

# ---------- 数据库配置 ----------
# 本地开发时修改为实际的 PostgreSQL 连接信息
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_chat_rag

# ---------- 智谱 BigModel LLM 配置（OpenAI 兼容）----------
LLM_API_KEY=your-zhipu-api-key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL_NAME=glm-4-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ---------- 智谱 AI Embedding 配置 ----------
# 如果 LLM 和 Embedding 用同一个服务商，API Key 可以相同
EMBEDDING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL_NAME=embedding-3
EMBEDDING_DIMENSION=2048

# ---------- 文档处理配置 ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
ENABLE_TOOLS=true
STRICT_GROUNDING=true
RAG_MIN_SCORE=0.55
TOOL_TIMEOUT_SEC=8
ENABLE_MCP=false
# 本地直接运行 uvicorn 时可用 localhost
MCP_BRIDGE_URL=http://localhost:9000
MCP_API_KEY=
MCP_WEB_TOOL_NAME=web_search
MCP_TIMEOUT_SEC=12
MCP_MAX_RESULTS=5

# ---------- CORS 配置 ----------
# 多个地址用 JSON 数组格式
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
